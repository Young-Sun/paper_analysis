{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83d\udcda My AI Paper Archive","text":"<p>\uc774\uacf3\uc740 \uad00\uc2ec \uc788\ub294 AI/ML \uc5f0\uad6c \ub17c\ubb38\ub4e4\uc744 \uc790\ub3d9\uc73c\ub85c \uc218\uc9d1\ud558\uace0 \ubd84\uc11d\ud558\uc5ec \uc815\ub9ac\ud558\ub294 \uac1c\uc778 \uc9c0\uc2dd \ubcf4\uad00\uc18c\uc785\ub2c8\ub2e4.</p>"},{"location":"#_1","title":"\ud83d\uddc2\ufe0f \ucd5c\uadfc \ubd84\uc11d\ub41c \ub17c\ubb38","text":"<p>\uc67c\ucabd \uc0ac\uc774\ub4dc\ubc14(\uba54\ub274)\uc5d0\uc11c \ubd84\uc11d\uc774 \uc644\ub8cc\ub41c \ub17c\ubb38 \ubaa9\ub85d\uc744 \ud655\uc778\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.  \uac01 \ubb38\uc11c\ub294 \ud575\uc2ec \uc694\uc57d, \ubc29\ubc95\ub860, \uc778\uc0ac\uc774\ud2b8 \ubc0f \ucd94\ucd9c\ub41c \uc774\ubbf8\uc9c0\ub97c \ud3ec\ud568\ud569\ub2c8\ub2e4.</p> <ul> <li>\uad6c\ucd95 \ud658\uacbd: GitHub Actions + Gemini * Pro / Flash + MkDocs</li> </ul>"},{"location":"2601_15621/","title":"Analysis: 2601_15621","text":""},{"location":"2601_15621/#qwen3-tts-technical-report","title":"Qwen3-TTS Technical Report \uc694\uc57d","text":"<p>\uc774 \ubb38\uc11c\ub294 Qwen Team\uc5d0\uc11c \ubc1c\ud45c\ud55c Qwen3-TTS \uc2dc\ub9ac\uc988\uc5d0 \ub300\ud55c \uae30\uc220 \ubcf4\uace0\uc11c\uc785\ub2c8\ub2e4. Qwen3-TTS\ub294 \ub2e4\uad6d\uc5b4 \uc9c0\uc6d0, \uc81c\uc5b4 \uac00\ub2a5\uc131, \uacac\uace0\uc131, \uc2a4\ud2b8\ub9ac\ubc0d \uae30\ub2a5\uc744 \uac16\ucd98 \ucd5c\ucca8\ub2e8 \ud14d\uc2a4\ud2b8 \uc74c\uc131 \ubcc0\ud658(Text-to-Speech, TTS) \ubaa8\ub378\uad70\uc744 \uc18c\uac1c\ud569\ub2c8\ub2e4.</p>"},{"location":"2601_15621/#_1","title":"\uc8fc\uc694 \ud2b9\uc9d5 \ubc0f \uc131\ub2a5","text":"<ol> <li>\ucd5c\ucca8\ub2e8 \uc74c\uc131 \ubcf5\uc81c \ubc0f \uc81c\uc5b4:<ul> <li>3\ucd08 \uc74c\uc131 \ubcf5\uc81c\ub97c \uc9c0\uc6d0\ud569\ub2c8\ub2e4.</li> <li>\uc124\uba85 \uae30\ubc18 \uc81c\uc5b4(Description-based Control)\ub97c \ud1b5\ud574 \uc644\uc804\ud788 \uc0c8\ub85c\uc6b4 \ubaa9\uc18c\ub9ac\ub97c \ub9cc\ub4e4\uac70\ub098 \ucd9c\ub825 \uc74c\uc131\uc5d0 \ub300\ud55c \uc138\ubc00\ud55c \uc870\uc791\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</li> </ul> </li> <li>\ub300\uaddc\ubaa8 \ub2e4\uad6d\uc5b4 \uc9c0\uc6d0:<ul> <li>10\uac1c \uc5b8\uc5b4\uc5d0 \uac78\uccd0 5\ubc31\ub9cc \uc2dc\uac04 \uc774\uc0c1\uc758 \uc74c\uc131 \ub370\uc774\ud130\ub85c \ud6c8\ub828\ub418\uc5c8\uc2b5\ub2c8\ub2e4.</li> <li>\uc2a4\ud53c\ucee4 \uc77c\uad00\uc131\uc744 \uc720\uc9c0\ud558\ub294 \ub2e4\uad6d\uc5b4 \uc0dd\uc131\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</li> </ul> </li> <li>\uc2e4\uc2dc\uac04 \uc2a4\ud2b8\ub9ac\ubc0d:<ul> <li>\ub4c0\uc5bc \ud2b8\ub799 LM \uc544\ud0a4\ud14d\ucc98\ub97c \ucc44\ud0dd\ud558\uc5ec \uc2e4\uc2dc\uac04 \ud569\uc131\uc744 \uc9c0\uc6d0\ud569\ub2c8\ub2e4.</li> <li>\ucd5c\uc18c 97ms (0.6B \ubaa8\ub378)\uc758 \uccab \ud328\ud0b7 \uc9c0\uc5f0 \uc2dc\uac04(First-Packet Latency)\uc744 \ub2ec\uc131\ud558\uc5ec \ucd08\uc800\uc9c0\uc5f0 \uc2a4\ud2b8\ub9ac\ubc0d\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</li> </ul> </li> <li>\ub3c5\ucc3d\uc801\uc778 \uc2a4\ud53c\uce58 \ud1a0\ud06c\ub098\uc774\uc800:<ul> <li>Qwen-TTS-Tokenizer-25Hz: 25Hz\uc758 \ub2e8\uc77c \ucf54\ub4dc\ubd81 \ucf54\ub371\uc73c\ub85c \uc758\ubbf8\ub860\uc801 \ucf58\ud150\uce20\uc5d0 \uc911\uc810\uc744 \ub450\uba70, Qwen-Audio\uc640 \uc6d0\ud65c\ud558\uac8c \ud1b5\ud569\ub418\uc5b4 \uc2a4\ud2b8\ub9ac\ubc0d \ud30c\ud615 \uc7ac\uad6c\uc131\uc744 \uc704\ud574 \ube14\ub85d \ub2e8\uc704 DiT\ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4.</li> <li>Qwen-TTS-Tokenizer-12Hz: 12.5Hz\uc758 16\uacc4\uce35 \uba40\ud2f0 \ucf54\ub4dc\ubd81 \uc124\uacc4\ub97c \uc0ac\uc6a9\ud558\uc5ec \uadf9\ub2e8\uc801\uc778 \ube44\ud2b8 \uc804\uc1a1\ub960 \uac10\uc18c\uc640 \ucd08\uc800\uc9c0\uc5f0 \uc2a4\ud2b8\ub9ac\ubc0d\uc744 \ub2ec\uc131\ud558\uba70, \uacbd\ub7c9 \uce90\uc8fc\uc5bc ConvNet\uc744 \ud1b5\ud574 \ud30c\ud615\uc744 \uc7ac\uad6c\uc131\ud569\ub2c8\ub2e4.</li> </ul> </li> </ol>"},{"location":"2601_15621/#_2","title":"\ubaa8\ub378 \uc544\ud0a4\ud14d\ucc98 \ubc0f \ud6c8\ub828","text":"<ul> <li>\uc544\ud0a4\ud14d\ucc98: Qwen3 LM \uc81c\ud488\uad70\uc744 \ud65c\uc6a9\ud558\uba70, \ud14d\uc2a4\ud2b8 \ud1a0\ud070\uacfc \uc74c\uc131 \ud1a0\ud070\uc744 \ucc44\ub110 \ucd95\uc73c\ub85c \uc5f0\uacb0\ud558\ub294 \ub4c0\uc5bc \ud2b8\ub799 \ud45c\ud604\uc744 \uc0ac\uc6a9\ud558\uc5ec \uc2e4\uc2dc\uac04 \ud569\uc131\uc744 \uc218\ud589\ud569\ub2c8\ub2e4.<ul> <li>Qwen3-TTS-25Hz: \ub2e8\uc77c \ub808\ubca8 \uc74c\uc131 \ud1a0\ud070\uc744 \uc0ac\uc6a9\ud558\uba70, \uccad\ud06c \ub2e8\uc704 DiT \ubaa8\ub4c8\ub85c \ud30c\ud615\uc744 \uc7ac\uad6c\uc131\ud569\ub2c8\ub2e4.</li> <li>Qwen3-TTS-12Hz: RVQ \ud1a0\ud070\uc744 \uc0ac\uc6a9\ud558\uba70, \uc81c\ub85c\ubd07 \ucf54\ub4dc\ubd81\uc744 \uc608\uce21\ud55c \ud6c4 MTP(Multi-Token Prediction) \ubaa8\ub4c8\uc774 \uc794\uc5ec \ucf54\ub4dc\ubd81\uc744 \uc0dd\uc131\ud558\ub294 \uacc4\uce35\uc801 \uc608\uce21 \ubc29\uc2dd\uc744 \ucc44\ud0dd\ud569\ub2c8\ub2e4.</li> </ul> </li> <li>\ud6c8\ub828 \ub2e8\uacc4:<ul> <li>\uc0ac\uc804 \ud6c8\ub828 (Pre-training): (S1) \uc77c\ubc18 \ub2e4\uad6d\uc5b4 \ub370\uc774\ud130 \ud559\uc2b5, (S2) \uace0\ud488\uc9c8 \ub370\uc774\ud130\ub85c \uc9c0\uc18d\uc801\uc778 \uc0ac\uc804 \ud6c8\ub828(CPT), (S3) \ucd5c\ub300 \ud1a0\ud070 \uae38\uc774\ub97c 32,768\ub85c \ub298\ub824 \uc7a5\ubb38 \ucc98\ub9ac \ub2a5\ub825 \ud5a5\uc0c1.</li> <li>\uc0ac\ud6c4 \ud6c8\ub828 (Post-training): DPO(Direct Preference Optimization)\ub97c \uc0ac\uc6a9\ud558\uc5ec \uc778\uac04 \uc120\ud638\ub3c4\uc5d0 \ub9de\ucda4, GSPO \ubc0f \uacbd\ub7c9 \uc2a4\ud53c\ucee4 \ud30c\uc778 \ud29c\ub2dd\uc744 \ud1b5\ud574 \uc548\uc815\uc131\uacfc \ud45c\ud604\ub825\uc744 \ud5a5\uc0c1\uc2dc\ud0b5\ub2c8\ub2e4.</li> </ul> </li> </ul>"},{"location":"2601_15621/#_3","title":"\uc8fc\uc694 \uc2e4\ud5d8 \uacb0\uacfc","text":"<ul> <li>\uc81c\ub85c\uc0f7 \uc74c\uc131 \ubcf5\uc81c: Seed-TTS \ubca4\uce58\ub9c8\ud06c\uc5d0\uc11c \ucd5c\uc800 WER(1.24, test-en)\uc744 \ub2ec\uc131\ud558\uba70 SOTA\ub97c \uae30\ub85d\ud588\uc2b5\ub2c8\ub2e4. 12Hz \ubcc0\ud615 \ubaa8\ub378\uc774 25Hz \ubaa8\ub378\ubcf4\ub2e4 \ub0b4\uc6a9 \uc815\ud655\ub3c4(WER)\uc5d0\uc11c \uc6b0\uc218\ud588\uc2b5\ub2c8\ub2e4.</li> <li>\ub2e4\uad6d\uc5b4 \uc74c\uc131 \uc0dd\uc131: 10\uac1c \uc5b8\uc5b4 \uc911 6\uac1c \uc5b8\uc5b4\uc5d0\uc11c MiniMax-Speech \ubc0f ElevenLabs\ub97c \ub2a5\uac00\ud558\ub294 \uc6b0\uc218\ud55c \uc9c0\ub2a5\uc131(\ub0ae\uc740 WER)\uc744 \ubcf4\uc600\uc73c\uba70, \ubaa8\ub4e0 10\uac1c \ud3c9\uac00 \uc5b8\uc5b4\uc5d0\uc11c \uac00\uc7a5 \ub192\uc740 \uc2a4\ud53c\ucee4 \uc720\uc0ac\ub3c4 \uc810\uc218\ub97c \uae30\ub85d\ud588\uc2b5\ub2c8\ub2e4.</li> <li>\uad50\ucc28 \uc5b8\uc5b4 \uc0dd\uc131: zh-to-ko\uc640 \uac19\uc740 \uc5b4\ub824\uc6b4 \uc30d\uc5d0\uc11c \uc624\ub958\uc728\uc744 66%\uae4c\uc9c0 \uac10\uc18c\uc2dc\ud0a4\uba70 CosyVoice \uc2dc\ub9ac\uc988 \ub300\ube44 \ub6f0\uc5b4\ub09c \uad50\ucc28 \uc5b8\uc5b4 \uc77c\ubc18\ud654 \ub2a5\ub825\uc744 \ubcf4\uc5ec\uc8fc\uc5c8\uc2b5\ub2c8\ub2e4.</li> <li>\uc81c\uc5b4 \uac00\ub2a5\ud55c \uc74c\uc131 \uc0dd\uc131: InstructTTSEval \ubca4\uce58\ub9c8\ud06c\uc5d0\uc11c \uc74c\uc131 \uc124\uacc4(Voice Design) \uc2dc\ub098\ub9ac\uc624\uc5d0\uc11c \uc624\ud508\uc18c\uc2a4 \ubaa8\ub378 \uc911 SOTA\ub97c \ub2ec\uc131\ud588\uc73c\uba70, \ub300\uc0c1 \uc2a4\ud53c\ucee4 \ud3b8\uc9d1\uc5d0\uc11c GPT-4o-mini-tts\ub97c \ud06c\uac8c \ub2a5\uac00\ud588\uc2b5\ub2c8\ub2e4.</li> <li>\uc7a5\ubb38 \uc74c\uc131 \uc0dd\uc131: 10\ubd84 \uc774\uc0c1\uc758 \uae34 \uc624\ub514\uc624 \ud569\uc131\uc5d0\uc11c \uae30\uc874 \uccad\ud06c \uae30\ubc18 \uc2dc\uc2a4\ud15c\uc758 \uacbd\uacc4 \uc544\ud2f0\ud329\ud2b8 \uc5c6\uc774 \uc77c\uad00\uc131\uc744 \uc720\uc9c0\ud558\uba70, 25Hz \ubcc0\ud615 \ubaa8\ub378\uc774 \uac00\uc7a5 \ub0ae\uc740 WER(long-zh 1.517, long-en 1.225)\uc744 \uae30\ub85d\ud588\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"2601_15621/#_4","title":"\uacb0\ub860","text":"<p>Qwen3-TTS\ub294 \ub450 \uac00\uc9c0\uc758 \ud601\uc2e0\uc801\uc778 \uc2a4\ud53c\uce58 \ud1a0\ud06c\ub098\uc774\uc800\uc640 \ub4c0\uc5bc \ud2b8\ub799 \uad6c\uc870\ub97c \ud1b5\ud574 \uace0\ud488\uc9c8, \ub2e4\uad6d\uc5b4, \uc800\uc9c0\uc5f0 \uc2a4\ud2b8\ub9ac\ubc0d \ud569\uc131\uc774\ub77c\ub294 \ub2e4\uc591\ud55c \uc694\uad6c \uc0ac\ud56d\uc744 \ub2e8\uc77c \uc790\ub3d9 \ud68c\uadc0 \ud504\ub808\uc784\uc6cc\ud06c \ub0b4\uc5d0\uc11c \ud1b5\ud569\uc801\uc73c\ub85c \ud574\uacb0\ud588\uc2b5\ub2c8\ub2e4. \uc5f0\uad6c \ubc0f \uac1c\ubc1c \ucd09\uc9c4\uc744 \uc704\ud574 \ud1a0\ud06c\ub098\uc774\uc800\uc640 \ubaa8\ub378 \uc804\uccb4\uac00 Apache 2.0 \ub77c\uc774\uc120\uc2a4\ub85c \uacf5\uac1c\ub418\uc5c8\uc2b5\ub2c8\ub2e4.</p>"},{"location":"2601_15621/#figures","title":"Figures","text":""}]}