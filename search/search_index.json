{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83d\udcda My AI Paper Archive","text":"<p>\uc774\uacf3\uc740 \uad00\uc2ec \uc788\ub294 AI/ML \uc5f0\uad6c \ub17c\ubb38\ub4e4\uc744 \uc790\ub3d9\uc73c\ub85c \uc218\uc9d1\ud558\uace0 \ubd84\uc11d\ud558\uc5ec \uc815\ub9ac\ud558\ub294 \uac1c\uc778 \uc9c0\uc2dd \ubcf4\uad00\uc18c\uc785\ub2c8\ub2e4.</p>"},{"location":"#_1","title":"\ud83d\uddc2\ufe0f \ucd5c\uadfc \ubd84\uc11d\ub41c \ub17c\ubb38","text":"<p>\uc67c\ucabd \uc0ac\uc774\ub4dc\ubc14(\uba54\ub274)\uc5d0\uc11c \ubd84\uc11d\uc774 \uc644\ub8cc\ub41c \ub17c\ubb38 \ubaa9\ub85d\uc744 \ud655\uc778\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.  \uac01 \ubb38\uc11c\ub294 \ud575\uc2ec \uc694\uc57d, \ubc29\ubc95\ub860, \uc778\uc0ac\uc774\ud2b8 \ubc0f \ucd94\ucd9c\ub41c \uc774\ubbf8\uc9c0\ub97c \ud3ec\ud568\ud569\ub2c8\ub2e4.</p> <ul> <li>\uad6c\ucd95 \ud658\uacbd: GitHub Actions + Gemini * Pro / Flash + MkDocs</li> </ul>"},{"location":"2601_15621/","title":"Analysis 2601.15621","text":"<ul> <li>\uc6d0\ubb38: https://arxiv.org/abs/2601.15621</li> </ul>"},{"location":"2601_15621/#qwen3-tts","title":"Qwen3-TTS \uae30\uc220 \ubcf4\uace0\uc11c \ud575\uc2ec \uc694\uc57d","text":""},{"location":"2601_15621/#1","title":"1. \ud83c\udfaf \uc5f0\uad6c \ubaa9\uc801","text":"<p>Qwen3-TTS \uc2dc\ub9ac\uc988\ub294 \uace0\ud488\uc9c8, \ub2e4\uad6d\uc5b4 \uc9c0\uc6d0, \uc81c\uc5b4 \uac00\ub2a5\uc131, \uacac\uace0\uc131, \uc2a4\ud2b8\ub9ac\ubc0d \uae30\ub2a5\uc744 \ud1b5\ud569\ud55c \ucd5c\ucca8\ub2e8 \ud14d\uc2a4\ud2b8-\uc74c\uc131 \ubcc0\ud658(TTS) \ubaa8\ub378\uc744 \uac1c\ubc1c\ud558\ub294 \uac83\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4. \ud2b9\ud788, 3\ucd08 \ubd84\ub7c9\uc758 \uc9e7\uc740 \uc624\ub514\uc624\ub9cc\uc73c\ub85c \uc74c\uc131\uc744 \ubcf5\uc81c(Voice Cloning)\ud558\uace0, \uc790\uc5f0\uc5b4 \uc124\uba85\uc744 \ud1b5\ud574 \ucd9c\ub825 \uc74c\uc131\uc758 \uc138\ubd80 \uc18d\uc131\uc744 \uc81c\uc5b4\ud558\ub294 \ub2a5\ub825\uc744 \uc81c\uacf5\ud558\uc5ec AGI \uad6c\ud604\uc5d0 \ud544\uc218\uc801\uc778 \uc548\uc815\uc801\uc774\uace0 \uc778\uac04\uacfc \uc720\uc0ac\ud55c \uc74c\uc131 \ud569\uc131 \uc5ed\ub7c9\uc744 \ud655\ubcf4\ud558\uace0\uc790 \ud569\ub2c8\ub2e4.</p>"},{"location":"2601_15621/#2","title":"2. \ud83d\udee0\ufe0f \uc5f0\uad6c \ubc29\ubc95\ub860","text":"<p>Qwen3-TTS\ub294 \ub4c0\uc5bc \ud2b8\ub799(Dual-Track) LM \uc544\ud0a4\ud14d\ucc98\ub97c \ucc44\ud0dd\ud558\uc5ec \uc2e4\uc2dc\uac04 \ud569\uc131\uc744 \uc9c0\uc6d0\ud558\uba70, \ub450 \uac00\uc9c0 \uc8fc\uc694 \uc74c\uc131 \ud1a0\ud06c\ub098\uc774\uc800\ub97c \ud65c\uc6a9\ud569\ub2c8\ub2e4.</p> <ol> <li>Qwen-TTS-Tokenizer-25Hz:<ul> <li>\ud2b9\uc9d5: 25Hz\uc758 \ub2e8\uc77c \ucf54\ub4dc\ubd81(Single-codebook) \uae30\ubc18\uc73c\ub85c, \uc758\ubbf8\ub860\uc801 \ub0b4\uc6a9(Semantic Content)\uc744 \uac15\uc870\ud569\ub2c8\ub2e4.</li> <li>\uad6c\ud604: Qwen2-Audio \uc778\ucf54\ub354\ub97c \ud65c\uc6a9\ud558\uc5ec \ud559\uc2b5\ub418\uc5c8\uc73c\uba70, \uc2a4\ud2b8\ub9ac\ubc0d \ud30c\ud615 \uc7ac\uad6c\uc131\uc744 \uc704\ud574 \ube14\ub85d \uae30\ubc18\uc758 Diffusion Transformer(DiT)\ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4.</li> </ul> </li> <li>Qwen-TTS-Tokenizer-12Hz:<ul> <li>\ud2b9\uc9d5: 12.5Hz\uc758 \ucd08\uc800\uc9c0\uc5f0 \uc2a4\ud2b8\ub9ac\ubc0d\uc744 \uc704\ud574 \uac1c\ubc1c\ub41c \ub2e4\uc911 \ucf54\ub4dc\ubd81(Multi-codebook) \uc124\uacc4(16\uac1c \ub808\uc774\uc5b4)\ub97c \uc0ac\uc6a9\ud558\uba70, \uadf9\ub2e8\uc801\uc778 \ube44\ud2b8\ub808\uc774\ud2b8 \uac10\uc18c\ub97c \ub2ec\uc131\ud569\ub2c8\ub2e4.</li> <li>\uad6c\ud604: \uccab \ubc88\uc9f8 \ucf54\ub4dc\ubd81\uc740 \uc758\ubbf8\ub860\uc801 \ub0b4\uc6a9\uc744, \ud6c4\uc18d \ub808\uc774\uc5b4\ub294 \uc74c\ud5a5\uc801 \uc138\ubd80 \uc0ac\ud56d\uc744 \uc778\ucf54\ub529\ud569\ub2c8\ub2e4. \uacbd\ub7c9\uc758 \uc778\uacfc\uc801(Causal) ConvNet\uc73c\ub85c \ud30c\ud615\uc744 \uc7ac\uad6c\uc131\ud558\uba70, \uccab \ubc88\uc9f8 \ud328\ud0b7 \ubc29\ucd9c \uc9c0\uc5f0 \uc2dc\uac04(First-Packet Latency)\uc774 97ms\uc5d0 \ubd88\uacfc\ud569\ub2c8\ub2e4.</li> </ul> </li> </ol> <p>\ud6c8\ub828 \uacfc\uc815: *   \uc0ac\uc804 \ud6c8\ub828: 500\ub9cc \uc2dc\uac04 \uc774\uc0c1\uc758 \ub2e4\uad6d\uc5b4 \uc74c\uc131 \ub370\uc774\ud130\ub97c \uc0ac\uc6a9\ud558\uc5ec \uc77c\ubc18 \ub2a5\ub825 \ud655\ubcf4(S1), \uace0\ud488\uc9c8 \ub370\uc774\ud130\ub85c \uc5f0\uc18d \uc0ac\uc804 \ud6c8\ub828(S2), \ucd5c\ub300 \ud1a0\ud070 \uae38\uc774 \ud655\ub300\ub97c \ud1b5\ud55c \uc7a5\uae30 \ub9e5\ub77d \ud559\uc2b5(S3)\uc744 \uc218\ud589\ud588\uc2b5\ub2c8\ub2e4. *   \uc0ac\ud6c4 \ud6c8\ub828: DPO(Direct Preference Optimization) \ubc0f GSPO(Generalized Successive Preference Optimization)\ub97c \ud1b5\ud574 \uc778\uac04 \uc120\ud638\ub3c4\uc5d0 \ub9de\ucd94\uace0, \uacbd\ub7c9\ud654\ub41c \ud654\uc790 \ud30c\uc778 \ud29c\ub2dd\uc744 \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7ec\uc6c0\uacfc \uc81c\uc5b4\ub825\uc744 \ud5a5\uc0c1\uc2dc\ucf30\uc2b5\ub2c8\ub2e4.</p>"},{"location":"2601_15621/#3","title":"3. \ud83d\udca1 \uc8fc\uc694 \uacb0\uacfc","text":"<ul> <li>\ucd5c\ucca8\ub2e8 \uc131\ub2a5: \ub2e4\uc591\ud55c \uac1d\uad00\uc801 \ubc0f \uc8fc\uad00\uc801 \ubca4\uce58\ub9c8\ud06c(TTS \ub2e4\uad6d\uc5b4 \ud14c\uc2a4\ud2b8 \uc138\ud2b8, InstructTTSEval \ub4f1)\uc5d0\uc11c \ucd5c\uc2e0 \uae30\uc220(State-of-the-Art, SOTA) \uc131\ub2a5\uc744 \ub2ec\uc131\ud588\uc2b5\ub2c8\ub2e4.</li> <li>\uc74c\uc131 \ubcf5\uc81c: \uc81c\ub85c\uc0f7 \uc74c\uc131 \ubcf5\uc81c(Zero-Shot Voice Cloning)\uc5d0\uc11c SOTA\ub97c \ub2ec\uc131\ud588\uc73c\uba70, 10\uac1c \ud3c9\uac00 \uc5b8\uc5b4 \uc804\ubc18\uc5d0\uc11c \uc0c1\uc5c5\uc801 \ubaa8\ub378(MiniMax, ElevenLabs) \ub300\ube44 \uc6b0\uc218\ud55c \ud654\uc790 \uc720\uc0ac\uc131\uc744 \ubcf4\uc600\uc2b5\ub2c8\ub2e4.</li> <li>\uc81c\uc5b4 \uac00\ub2a5\uc131: \uc790\uc5f0\uc5b4 \uba85\ub839\uc744 \ud1b5\ud55c \uc74c\uc131 \uc124\uacc4(Voice Design) \ubc0f \uc81c\uc5b4 \ub2a5\ub825\uc5d0\uc11c GPT-4o-mini-tts\ub97c \ub2a5\uac00\ud558\ub294 \uc131\ub2a5\uc744 \ubcf4\uc600\uc2b5\ub2c8\ub2e4.</li> <li>\ucd08\uc800\uc9c0\uc5f0 \uc2a4\ud2b8\ub9ac\ubc0d: Qwen-TTS-Tokenizer-12Hz\ub97c \uc0ac\uc6a9\ud560 \uacbd\uc6b0, \ub2e8\uc77c \uc694\uccad \ud658\uacbd\uc5d0\uc11c 97ms\uc758 \ub9e4\uc6b0 \ub0ae\uc740 \uccab \ud328\ud0b7 \uc9c0\uc5f0 \uc2dc\uac04\uc744 \uae30\ub85d\ud558\uba70 \uc2e4\uc2dc\uac04 \uc560\ud50c\ub9ac\ucf00\uc774\uc158\uc5d0 \ub9e4\uc6b0 \uc801\ud569\ud569\ub2c8\ub2e4.</li> <li>\uc7a5\uae30 \uc548\uc815\uc131: 10\ubd84 \uc774\uc0c1\uc758 \uc7a5\uae30 \uc624\ub514\uc624 \uc0dd\uc131\uc5d0\uc11c\ub3c4 \uc790\uc5f0\uc2a4\ub7fd\uace0 \uc720\ucc3d\ud55c \ucd9c\ub825\uc774 \uac00\ub2a5\ud568\uc744 \uc785\uc99d\ud588\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"2601_15621/#4","title":"4. \ud83e\udde0 \ud575\uc2ec \uc778\uc0ac\uc774\ud2b8","text":"<p>Qwen3-TTS\ub294 \ud1a0\ud06c\ub098\uc774\uc800\uc758 \uc120\ud0dd(25Hz vs 12Hz)\uc744 \ud1b5\ud574 TTS \uc2dc\uc2a4\ud15c\uc758 \ud575\uc2ec \ubaa9\ud45c(\uc74c\uc9c8/\uc758\ubbf8\ub860 vs. \ucd08\uc800\uc9c0\uc5f0)\ub97c \uc815\uad50\ud558\uac8c \uc870\uc808\ud560 \uc218 \uc788\uc74c\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.</p> <ol> <li>\ud6a8\uc728\uc131\uacfc \ud488\uc9c8\uc758 \uade0\ud615: 12Hz \ud1a0\ud06c\ub098\uc774\uc800\ub294 \ub0ae\uc740 \uc0d8\ud50c\ub9c1 \ub808\uc774\ud2b8\uc640 \ub2e4\uc911 \ucf54\ub4dc\ubd81 \uad6c\uc870\ub97c \ud1b5\ud574 \ubcf5\uc7a1\ud55c \ud30c\ud615 \uc7ac\uad6c\uc131 \ubaa8\ub378(\uc608: DiT) \uc5c6\uc774\ub3c4 \uadf9\ub3c4\ub85c \ub0ae\uc740 \uc9c0\uc5f0 \uc2dc\uac04(97ms)\uc744 \ub2ec\uc131\ud558\uba74\uc11c\ub3c4 \ub0b4\uc6a9 \uc77c\uad00\uc131(WER) \uce21\uba74\uc5d0\uc11c 25Hz \ubaa8\ub378\ubcf4\ub2e4 \uc6b0\uc218\ud558\ub2e4\ub294 \uc810\uc740, TTS\uc758 \ubbf8\ub798\uac00 \ud6a8\uc728\uc801\uc778 \uc774\uc0b0 \ud45c\ud604 \ud559\uc2b5\uc5d0 \uc788\uc74c\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.</li> <li>LLM \uae30\ubc18 \uc81c\uc5b4\uc758 \uac15\ub825\ud568: \ub300\uaddc\ubaa8 \uc5b8\uc5b4 \ubaa8\ub378(Qwen3 LM) \uc544\ud0a4\ud14d\ucc98\ub97c \uae30\ubc18\uc73c\ub85c \ud6c8\ub828\ub418\uc5c8\uc73c\uba70 ChatML \ud615\uc2dd\uc744 \ucc44\ud0dd\ud568\uc73c\ub85c\uc368, \uc74c\uc131 \ubcf5\uc81c\ubfd0\ub9cc \uc544\ub2c8\ub77c \ubcf5\uc7a1\ud55c \uc790\uc5f0\uc5b4 \uc9c0\uce68\uc744 \ud1b5\ud55c \uc74c\uc131 \uc18d\uc131(Prosody, Style)\uc758 \uc12c\uc138\ud55c \uc81c\uc5b4(Fine-grained Control)\uac00 \uac00\ub2a5\ud574\uc84c\uc2b5\ub2c8\ub2e4.</li> <li>\ub2e4\uad6d\uc5b4 \ubc0f \uad50\ucc28 \uc5b8\uc5b4 \uc131\ub2a5: 500\ub9cc \uc2dc\uac04\uc758 \ub300\uaddc\ubaa8 \ub370\uc774\ud130 \ud559\uc2b5\uacfc \uccb4\uacc4\uc801\uc778 \ud6c8\ub828 \ub2e8\uacc4\ub97c \ud1b5\ud574, 10\uac1c \uc5b8\uc5b4\uc5d0\uc11c \uc0c1\uc5c5\uc801 \ubaa8\ub378 \ub300\ube44 \uc6b0\uc218\ud55c \ub0b4\uc6a9 \uc77c\uad00\uc131\uacfc \ud654\uc790 \uc720\uc0ac\uc131\uc744 \ud655\ubcf4\ud588\uc73c\uba70, \ud2b9\ud788 \uc911\uad6d\uc5b4\uc5d0\uc11c \ud55c\uad6d\uc5b4\ub85c\uc758 \uad50\ucc28 \uc5b8\uc5b4 \ubcf5\uc81c \uc131\ub2a5\uc774 \ub300\ud3ed \uac1c\uc120\ub418\uc5c8\uc2b5\ub2c8\ub2e4.</li> </ol>"},{"location":"2601_15621/#figures","title":"Figures","text":""}]}